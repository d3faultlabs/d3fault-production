# ─── Vite Dev Server ──────────────────────────────────────────────────────────
# TCP port the Vite dev server listens on
PORT=5173

# URL base path prefix — use "/" for root, or a sub-path like "/app"
BASE_PATH=/

# ─── Solana ───────────────────────────────────────────────────────────────────
# Network shown in the UI and used for RPC: mainnet-beta | devnet
VITE_SOLANA_NETWORK=devnet

# (Optional) Override the primary RPC URL used by the browser Solana client.
# If not set, falls back to the public RPC for the selected network.
# Example: https://devnet.helius-rpc.com/?api-key=<your-key>
VITE_SOLANA_RPC_ENDPOINT=# paste your value here (or leave blank for public RPC)

# (Optional) Secondary RPC endpoint — used as the first fallback before public RPCs.
# Useful for a paid Helius/Alchemy endpoint as the primary with a backup.
VITE_SOLANA_RPC_ENDPOINT_2=# paste your value here (optional)

# ─── Privy (Wallet Auth) ──────────────────────────────────────────────────────
# Privy App ID — found in your Privy dashboard. This is a public value;
# it is safe to embed in the browser bundle.
VITE_PRIVY_APP_ID=# paste your Privy App ID here
