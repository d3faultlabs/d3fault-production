# ─── Server ────────────────────────────────────────────────────────────────────
# TCP port the Express server listens on
PORT=3001

# Node environment — "development" or "production"
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — never commit this value
DATABASE_URL=postgres://user:password@localhost:5432/d3fault

# ─── Solana ───────────────────────────────────────────────────────────────────
# Network to connect to: mainnet-beta | devnet | localnet
SOLANA_NETWORK=devnet

# Primary Solana RPC endpoint (include your API key in the URL)
# Examples:
#   Helius devnet: https://devnet.helius-rpc.com/?api-key=<your-key>
#   Helius mainnet: https://mainnet.helius-rpc.com/?api-key=<your-key>
#   Public devnet (rate-limited): https://api.devnet.solana.com
SOLANA_RPC_ENDPOINT=# paste your value here

# Deployed Anchor program ID
PROGRAM_ID=2akvmbaGhGeAWVCQrpHXvJTZE9EksMk5rpHM4NcMmfKG

# ─── Relayer ──────────────────────────────────────────────────────────────────
# Base58-encoded private key of the relayer wallet.
# This wallet pays the Solana transaction fee for every withdrawal.
# Fund it before enabling withdrawals. NEVER expose this value client-side.
RELAYER_PRIVATE_KEY=# paste your base58 private key here

# ─── Privy (Auth) ─────────────────────────────────────────────────────────────
# Privy App ID — visible in your Privy dashboard (safe to share, also used by the frontend)
PRIVY_APP_ID=# paste your Privy App ID here

# Privy App Secret — server-side only. Found in Privy dashboard → Settings → API keys.
# Never expose this in the browser or frontend build.
PRIVY_APP_SECRET=# paste your Privy App Secret here
